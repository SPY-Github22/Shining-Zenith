{
    "manifest_version": 3,
    "name": "AI Honeypot - Scam Defense",
    "version": "3.0.0",
    "description": "An AI-powered honeypot that takes over scam calls, keeps scammers engaged, and extracts intelligence for law enforcement.",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://api.groq.com/*",
        "wss://speech.platform.bing.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon.svg",
            "48": "icons/icon.svg",
            "128": "icons/icon.svg"
        },
        "default_title": "AI Honeypot"
    },
    "background": {
        "service_worker": "background.js"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "icons": {
        "16": "icons/icon.svg",
        "48": "icons/icon.svg",
        "128": "icons/icon.svg"
    }
}